[user]
	name = Albert Yang
	email = albertesyang@gmail.com
[core]
	editor = 'nvim'
	pager = delta
[interactive]
	diffFilter = delta --color-only
[include]
	path = ~/.config/delta/catppuccin.gitconfig
[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	features = catppuccin-frappe
[merge]
	conflictstyle = diff3
[diff]
	colorMoved = default
